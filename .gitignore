# Personal vault — note content local; README in git (templates at repo root)
vault/*
!vault/README.md

# Folder placeholders (README only; daily notes stay ignored)
!vault/issues/
vault/issues/*
!vault/issues/README.md
!vault/learnings/
vault/learnings/*
!vault/learnings/README.md

# Obsidian settings (vault folder = Obsidian vault root)
!vault/.obsidian/
!vault/.obsidian/**

# Cursor local setup (junctions from scripts/setup-windows.ps1 — edit ai-skills/ ai-rules/)
.cursor/
